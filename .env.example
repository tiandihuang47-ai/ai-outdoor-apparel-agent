AI_PROVIDER=mock
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# 用户认证与历史记录持久化
# 本地开发：至少 32 位随机字符串
AUTH_SECRET=your-local-auth-secret-at-least-32-characters-long
# 邮件发送（可选），未配置时验证码会输出在服务端控制台
RESEND_API_KEY=

# Vercel KV（可选），未配置时登录/历史 API 会报错
# 在 Vercel Dashboard 绑定 KV 后自动生成
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
